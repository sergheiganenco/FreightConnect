# === REQUIRED ===
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/freightconnect?retryWrites=true&w=majority
JWT_SECRET=<generate-64-char-random-string>
NODE_ENV=production
PORT=5000

# === FRONTEND ===
REACT_APP_API_URL=/api
FRONTEND_URL=https://yourdomain.com

# === CORS ===
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# === STRIPE ===
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# === EXTERNAL APIS ===
ORS_API_KEY=<openrouteservice-key>
FMCSA_API_KEY=<fmcsa-safer-key>

# === EMAIL (SMTP) ===
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASS=<smtp-password>

# === DOCKER MONGO (if using local mongo) ===
MONGO_USER=admin
MONGO_PASS=<strong-password>
