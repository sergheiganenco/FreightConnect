MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/FreightConnect
PORT=5000
JWT_SECRET=generate-a-64-char-random-string-here
JWT_EXPIRES_IN=1d
ORS_API_KEY=your-openrouteservice-api-key
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-key
# Path B off-session accessorial (detention) collection. Leave FALSE until the
# flow has been field-tested — enabling Stripe alone will NOT turn it on.
# When false, approved detention settles via Path A (accrual) as today.
ENABLE_ACCESSORIAL_COLLECTION=false
FMCSA_API_KEY=your-fmcsa-api-key
# HMAC key for stateless per-load GPS-ingest tokens (OwnTracks/Traccar).
# Falls back to JWT_SECRET if unset; set a dedicated secret in production.
TRACKING_TOKEN_SECRET=generate-a-separate-random-string-here
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development
# Per-IP general API rate limit (requests/minute). Default 100.
RATE_LIMIT_MAX=100
