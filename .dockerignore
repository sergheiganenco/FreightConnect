# Dependencies
node_modules/
*/node_modules/
**/node_modules/

# Environment files
.env
.env.*
*.env

# Git
.git/
.gitignore

# Mobile app (not deployed to web)
mobile/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# Build artifacts (rebuilt in Docker)
frontend/build/
dist/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Documentation
*.md
LICENSE

# Docker files (prevent recursive build context)
docker-compose*.yml
Dockerfile

# Claude Code
.claude/

# Test files
**/__tests__/
**/*.test.js
**/*.spec.js
coverage/
jest.config.js

# Uploaded documents (ephemeral in containers, use volumes)
backend/public/documents/uploads/*
